NODE_ENV=production
PORT=3001

# Public URLs
CORS_ORIGIN=https://your-domain.com
WEB_APP_URL=https://your-domain.com
APP_WEB_URL=https://your-domain.com
API_PUBLIC_URL=https://your-domain.com/api

# PocketBase
# For Docker Compose use: http://pocketbase:8090
# For local non-Docker use: http://127.0.0.1:8090
PB_BASE_URL=http://pocketbase:8090
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=replace_me

# Pinterest API credentials
PINTEREST_CLIENT_ID=replace_me
PINTEREST_CLIENT_SECRET=replace_me
PINTEREST_REDIRECT_URI=https://your-domain.com/api/pinterest/oauth/callback
PINTEREST_SCOPES=boards:read,pins:read,pins:write,user_accounts:read

# PocketBase OAuth2 providers for app sign-in/linking
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# Queue tuning
PINTEREST_QUEUE_POLL_MS=15000
PINTEREST_QUEUE_BATCH=10
AI_IMAGE_QUEUE_POLL_MS=12000
AI_IMAGE_QUEUE_BATCH=5

# OpenAI Images API
OPENAI_IMAGES_MODEL=gpt-image-1
OPENAI_IMAGES_SIZE=1024x1536

# Integrated AI proxy
INTEGRATED_AI_API_URL=https://integrated-ai.example.com
INTEGRATED_AI_API_KEY=replace_me
WEBSITE_ID=replace_me
WEBSITE_DOMAIN=your-domain.com
PROXY_ENTRANCE_ID=

# Secrets and optional infra
# Use 64 hex chars for each key.
PB_ENCRYPTION_KEY=replace_with_64_hex_chars
WORDPRESS_SECRETS_KEY=replace_with_64_hex_chars
REDIS_URL=
